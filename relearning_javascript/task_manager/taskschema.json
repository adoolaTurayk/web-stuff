{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "import",
    "description": "Definition of the import format for the task manager",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "body": {
                "type": "string",
                "minLength": 1
            },
            "date": {
                "type": ["string", "null"],
                "format": "date"
            },
            "time": {
                "type": ["string", "null"],
                "format": "time"
            },
            "finished": {
                "type": "boolean"
            }
        },
        "required": ["body", "finished"],
        "additionalProperties": false,

        "allOf": [
            {
                "if": {
                    "properties": {
                        "time": {
                            "type": "string"
                        }
                    },
                    "required": ["time"]
                },
                "then": {
                    "required": ["date"]
                }
            }
        ]
    }
}